# ============================================================================
# AutoHarvester Backend — Environment Template
# ----------------------------------------------------------------------------
# Copy to `.env` for local dev, or paste into Railway / Render environment.
# All STRIPE_* are OPTIONAL on first boot — backend will start without them
# and surface clean 503s on billing endpoints until they are populated.
# ============================================================================

# ── Database (Neon PostgreSQL recommended, region: Singapore for AU latency)
DATABASE_URL=postgresql://username:password@host/database?sslmode=require

# ── Security (REQUIRED in production — generate with `openssl rand -base64 32`)
JWT_SECRET=your-jwt-secret-min-32-characters-long-change-this
SESSION_SECRET=your-session-secret-min-32-characters-long-change-this

# ── App
FRONTEND_URL=https://autoharvester.com.au
PORT=3001
NODE_ENV=production

# ── Stripe (OPTIONAL on first deploy — see DEPLOY.md step 4)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Canonical 5-SKU pricing — populate after running `npm run stripe:setup`
STRIPE_PRICE_REPORT=
STRIPE_PRICE_WATCHLIST_MONTHLY=
STRIPE_PRICE_WATCHLIST_YEARLY=
STRIPE_PRICE_EDGE_MONTHLY=
STRIPE_PRICE_EDGE_YEARLY=
STRIPE_PRICE_INVENTORY_IQ_MONTHLY=
STRIPE_PRICE_INVENTORY_IQ_YEARLY=
STRIPE_PRICE_GROUP_MONTHLY=
STRIPE_PRICE_GROUP_YEARLY=

# ── Legacy Stripe slots (DEPRECATED — auto-alias to canonical SKUs if set;
# leave blank for new deployments)
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_DEALER_MONTHLY=
STRIPE_PRICE_DEALER_YEARLY=

# ── Email digest provider (one of: log | resend | postmark)
EMAIL_PROVIDER=log
RESEND_API_KEY=
POSTMARK_API_KEY=
EMAIL_FROM=alerts@autoharvester.com.au
DIGEST_WINDOW_DAYS=7
DIGEST_DRY_RUN=false

# ── External data providers (mock until configured)
PPSR_PROVIDER=mock
NEVDIS_PROVIDER=mock
